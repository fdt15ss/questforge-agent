# Production Environment - Gemini
ENVIRONMENT=production
HOST=0.0.0.0
PORT=18000
APP=app:create_app

# Gemini / Google Gen AI
GEMINI_API_KEY=
QUESTFORGE_LLM_DEFAULT_PROVIDER=google
QUESTFORGE_LLM_DEFAULT_MODEL=gemini-2.5-flash

# Local fallback. Start Ollama separately before using this fallback.
QUESTFORGE_LLM_FALLBACK1_PROVIDER=local
QUESTFORGE_LLM_FALLBACK1_MODEL=gemma4:e4b
QUESTFORGE_LLM_FALLBACK1_BASE_URL=http://127.0.0.1:11434/v1
QUESTFORGE_LLM_FALLBACK2_PROVIDER=none

QUESTFORGE_LLM_TIMEOUT_MS=120000
QUESTFORGE_LLM_MAX_OUTPUT_TOKENS=2048
QUESTFORGE_LLM_TEMPERATURE=0.2
