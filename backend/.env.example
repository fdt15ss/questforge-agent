# Application Environment
# ENVIRONMENT=development
# ENVIRONMENT=production

# LLM slot configuration
# Dev mode uses local LLM as the default slot.
QUESTFORGE_LLM_DEFAULT_PROVIDER=local
QUESTFORGE_LLM_DEFAULT_MODEL=llama3.1:8b
QUESTFORGE_LLM_DEFAULT_BASE_URL=http://localhost:11434/v1
# QUESTFORGE_LLM_DEFAULT_API_KEY=

# Optional fallback slots. Leave as none for local development without remote APIs.
QUESTFORGE_LLM_FALLBACK1_PROVIDER=none
# QUESTFORGE_LLM_FALLBACK1_MODEL=
# QUESTFORGE_LLM_FALLBACK1_BASE_URL=
# QUESTFORGE_LLM_FALLBACK1_API_KEY=

QUESTFORGE_LLM_FALLBACK2_PROVIDER=none
# QUESTFORGE_LLM_FALLBACK2_MODEL=
# QUESTFORGE_LLM_FALLBACK2_BASE_URL=
# QUESTFORGE_LLM_FALLBACK2_API_KEY=

QUESTFORGE_LLM_TIMEOUT_MS=20000
QUESTFORGE_LLM_MAX_OUTPUT_TOKENS=2048
QUESTFORGE_LLM_TEMPERATURE=0.2

# Provider API keys
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Logging
# LOG_LEVEL=INFO

# Smoke test runner
QUESTFORGE_SMOKE_BASE_URL=http://127.0.0.1:18000
QUESTFORGE_SMOKE_WS_PATH=/ws/agent
# QUESTFORGE_SMOKE_EXTERNAL_PROVIDER=1
