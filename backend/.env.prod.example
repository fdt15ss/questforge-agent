# Production Environment
ENVIRONMENT=production
HOST=0.0.0.0
PORT=18000
APP=app:create_app

# If QUESTFORGE_LLM_DEFAULT_PROVIDER is omitted:
# 1. GEMINI_API_KEY or GOOGLE_API_KEY selects Gemini automatically.
# 2. OPENAI_API_KEY selects OpenAI automatically.
# 3. No key leaves the LLM disabled and the agent uses deterministic fallback.

# Gemini / Google Gen AI
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# QUESTFORGE_LLM_DEFAULT_MODEL=gemini-2.5-flash

# OpenAI
# OPENAI_API_KEY=
# QUESTFORGE_LLM_DEFAULT_MODEL=gpt-4o-mini

# Explicit provider override. Uncomment only when you do not want auto-detection.
# QUESTFORGE_LLM_DEFAULT_PROVIDER=google
# QUESTFORGE_LLM_DEFAULT_PROVIDER=openai
# QUESTFORGE_LLM_DEFAULT_PROVIDER=none

QUESTFORGE_LLM_TIMEOUT_MS=120000
QUESTFORGE_LLM_MAX_OUTPUT_TOKENS=2048
QUESTFORGE_LLM_TEMPERATURE=0.2
